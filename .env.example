# AI SDR Configuration
# Copy to .env and fill in your values

# ── App ──────────────────────────────────────────────────
APP_NAME=ai-sdr
DEBUG=false
API_KEY=  # Set a strong API key for authentication

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ai_sdr:ai_sdr@localhost:5432/ai_sdr
DB_POOL_SIZE=10

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LLM (via LiteLLM) ───────────────────────────────────
LLM_PROVIDER=anthropic
LLM_MODEL_FAST=claude-haiku-4-5-20251001
LLM_MODEL_MID=claude-sonnet-4-6
LLM_API_KEY=sk-ant-...  # Your Anthropic API key
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3

# ── Email ────────────────────────────────────────────────
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_xxxx
EMAIL_FROM_ADDRESS=sdr@yourcompany.com
EMAIL_FROM_NAME=Your Company SDR

# ── Calendar ─────────────────────────────────────────────
CALCOM_API_KEY=
CALCOM_BASE_URL=https://api.cal.com/v2

# ── CRM (Salesforce) ────────────────────────────────────
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=
SALESFORCE_DOMAIN=login  # "login" for prod, "test" for sandbox

# ── Slack ────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Web Scraping ─────────────────────────────────────────
SCRAPER_USER_AGENT=AI-SDR-Bot/0.1
SCRAPER_RATE_LIMIT_SECONDS=2.0

# DuckDuckGo (free, no API key required)
DUCKDUCKGO_MAX_RESULTS=10

# Railway
PORT=8000
